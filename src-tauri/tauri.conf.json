{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "快乐背单词",
  "version": "0.1.0",
  "identifier": "com.kidsvocab.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "windows": [
      {
        "title": "🐣 快乐背单词 - Kids Vocabulary",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "minWidth": 1280,
        "minHeight": 800,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
